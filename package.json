{
    "name": "promise9",
    "version": "0.0.1",
    "description": "",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "packageManager": "bun@1.3.14",
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "build:nest": "nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"script/**/*.ts\" \"drizzle.config.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "image-color:preview": "ts-node test/manual/image-color-preview.ts",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "db:backup": "bun run script/backup-db.ts",
        "db:backup:verify": "bun run script/verify-db-backup.ts",
        "db:restore": "bun run script/restore-db.ts",
        "db:health": "bun run script/db-health.ts",
        "db:seed:master": "bun run script/seed-master-user.ts",
        "db:visualize_mermaid": "bun run script/visualize-db-mermaid.ts",
        "ui": "bun run script/ui/index.ts",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" \"drizzle.config.ts\"",
        "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" \"drizzle.config.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "prepare": "husky"
    },
    "dependencies": {
        "@google/genai": "^2.10.0",
        "@nestjs/common": "^11.0.1",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.0.1",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.0.1",
        "@nestjs/swagger": "^11.4.4",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "dotenv": "^17.4.2",
        "drizzle-orm": "^0.45.2",
        "google-auth-library": "^10.9.0",
        "node-vibrant": "^4.0.4",
        "openai": "^6.45.0",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "postgres": "^3.4.9",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "sharp": "^0.35.2",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.2.0",
        "@eslint/js": "^9.18.0",
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.1",
        "@swc/cli": "^0.6.0",
        "@swc/core": "^1.10.7",
        "@types/express": "^5.0.0",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.10.7",
        "@types/passport": "^1.0.17",
        "@types/passport-jwt": "^4.0.1",
        "@types/supertest": "^6.0.2",
        "drizzle-kit": "^0.31.10",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-prettier": "^5.2.2",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "globals": "^16.0.0",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "lint-staged": "^17.0.7",
        "prettier": "^3.4.2",
        "source-map-support": "^0.5.21",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.20.0"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    },
    "lint-staged": {
        "*.ts": [
            "eslint --fix"
        ]
    }
}
