APP_ENV=development
DATABASE_URL_DEVELOPMENT=postgres://postgres:postgres@localhost:5432/promise9
DATABASE_URL_PRODUCTION=postgres://user:password@host:5432/promise9?sslmode=verify-full
DB_POOL_SIZE=5

LLM_DEFAULT_MODEL=gpt-5.4-mini
LLM_REQUEST_TIMEOUT_MS=30000

# 사용하는 provider의 API key만 설정한다.
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# 필수
JWT_ACCESS_SECRET=your-access-secret-here
# 필수
JWT_REFRESH_SECRET=your-refresh-secret-here
# 선택 | 기본값: 15m
#JWT_ACCESS_EXPIRES_IN=15m
# 선택 | 기본값: 30d
#JWT_REFRESH_EXPIRES_IN=30d
# 필수
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# 선택 | 테스트용 마스터 토큰 (설정 시 해당 토큰으로 인증 우회, 프로덕션 미설정 권장)
#MASTER_ACCESS_TOKEN=
# 선택 | 마스터 토큰으로 인증될 유저 ID | 기본값: 1
#MASTER_USER_ID=1
